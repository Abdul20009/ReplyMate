{
  "manifest_version": 3,
  "name": "ReplyMate",
  "version": "1.0.0",
  "description": "AI-powered reply suggestions for WhatsApp Web. You always decide what to send.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://web.whatsapp.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ReplyMate"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}